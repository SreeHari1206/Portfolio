}

.card{
width:80%;
margin:auto;
background:white;
border-radius:15px;
overflow:hidden;
box-shadow:0 5px 20px rgba(0,0,0,0.15);
transition:.3s;
}

.card:hover{
transform:translateY(-10px);
}

.card img{
width:100%;
}

.card-content{
padding:30px;
}

.tags span{
background:#0c2340;
color:white;
padding:8px 15px;
border-radius:20px;
