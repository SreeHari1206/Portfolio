```css
body{
font-family:Segoe UI;
margin:0;
background:#f4f7fb;
color:#333;
}

header{
background:#0c2340;
color:white;
padding:30px;
text-align:center;
}

nav{
margin-top:20px;
}

nav a{
color:white;
text-decoration:none;
margin:20px;
